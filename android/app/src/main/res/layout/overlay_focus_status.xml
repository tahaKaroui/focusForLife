<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="18dp">

    <LinearLayout
        android:id="@+id/overlayBubble"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:background="@drawable/overlay_bubble_bg"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- Hourly time left (big) -->
        <TextView
            android:id="@+id/overlayBubbleTime"
            android:text="07:00"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/urbanist"
            android:includeFontPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Daily time left (small, brand orange) -->
        <TextView
            android:id="@+id/overlayBubbleLabel"
            android:text="60:00"
            android:textColor="#F2A33C"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="@font/urbanist"
            android:includeFontPadding="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View
        android:id="@+id/overlayMinimized"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:background="@drawable/overlay_bubble_bg"
        android:elevation="6dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/overlayExpanded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/overlay_card_bg"
        android:elevation="8dp"
        android:minWidth="200dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/overlayTitle"
            android:fontFamily="@font/urbanist"
            android:text="TIME LEFT"
            android:textColor="#F2A33C"
            android:textStyle="bold"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/overlayHourlyValue"
            android:fontFamily="@font/urbanist"
            android:text="This hour · 07:00"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <ProgressBar
            android:id="@+id/overlayHourlyBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="100"
            android:progressTint="#F2A33C"
            android:progressBackgroundTint="#26FFFFFF" />

        <TextView
            android:id="@+id/overlayDailyValue"
            android:fontFamily="@font/urbanist"
            android:text="Today · 60:00"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <ProgressBar
            android:id="@+id/overlayDailyBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="100"
            android:progressTint="#55A3B5"
            android:progressBackgroundTint="#26FFFFFF" />
    </LinearLayout>
</FrameLayout>
