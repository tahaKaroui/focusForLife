<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher foreground: the FocusForLife shield centered in the 108dp
     viewport (66dp safe zone). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="25.2"
        android:translateY="25.2"
        android:scaleX="2.4"
        android:scaleY="2.4">

        <!-- Outer shield (teal) -->
        <path
            android:fillColor="#18586B"
            android:pathData="M12,1.6 L20.4,4.7 L20.4,11 C20.4,16.7 17,20.8 12,22.5 C7,20.8 3.6,16.7 3.6,11 L3.6,4.7 Z" />

        <!-- Inner shield (orange) -->
        <group
            android:pivotX="12"
            android:pivotY="12"
            android:scaleX="0.78"
            android:scaleY="0.78">
            <path
                android:fillColor="#F2A33C"
                android:pathData="M12,1.6 L20.4,4.7 L20.4,11 C20.4,16.7 17,20.8 12,22.5 C7,20.8 3.6,16.7 3.6,11 L3.6,4.7 Z" />
        </group>

        <!-- Rising arrow (white) -->
        <group
            android:pivotX="12"
            android:pivotY="12"
            android:scaleX="0.52"
            android:scaleY="0.52">
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M16,6 L18.29,8.29 L13.41,13.17 L9.41,9.17 L2,16.59 L3.41,18 L9.41,12 L13.41,16 L19.71,9.71 L22,12 L22,6 Z" />
        </group>
    </group>
</vector>
